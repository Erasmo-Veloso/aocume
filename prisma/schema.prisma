// AOCUME — Prisma schema
// Base de dados: Supabase Postgres. Acesso via Prisma (híbrido); o Storage de
// imagens usa o SDK do Supabase (ver src/lib/storage.ts).
//
// DATABASE_URL  → pooler do Supabase (porta 6543, ?pgbouncer=true) — runtime
// DIRECT_URL    → ligação directa (porta 5432) — usada pelo Prisma Migrate

generator client {
  provider      = "prisma-client-js"
  // Output por omissão (node_modules/.prisma/client) — o Next/Vercel tratam
  // automaticamente do motor. "native" para local; "rhel-openssl-3.0.x" para
  // o runtime serverless da Vercel.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductType {
  ORDER
  READY_STOCK
}

enum PaymentType {
  PARTIAL
  FULL
}

enum ProfitBasis {
  GROSS
  NET
}

enum TestimonialFormat {
  TEXT
  IMAGE
  VIDEO
}

model Administrator {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("administrators")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]

  @@map("categories")
}

model Product {
  id               String         @id @default(uuid())
  categoryId       String         @map("category_id")
  reference        String         @unique
  title            String
  slug             String         @unique
  shortDescription String         @map("short_description")
  description      String
  price            Int? // AOA (número inteiro); null = "sob consulta"
  productType      ProductType    @default(ORDER) @map("product_type")
  paymentType      PaymentType    @default(PARTIAL) @map("payment_type")
  minimumQuantity  Int            @default(1) @map("minimum_quantity")
  deliveryTime     String         @map("delivery_time")
  availableQuantity Int?          @map("available_quantity")
  featured         Boolean        @default(false)
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  category Category       @relation(fields: [categoryId], references: [id])
  images   ProductImage[]

  @@index([categoryId])
  @@index([featured])
  @@index([active])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  url       String
  alt       String?
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model BusinessPackage {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  tagline         String
  image           String?
  investment      Int // AOA
  currency        String        @default("AOA")
  profitMargin    String        @map("profit_margin")
  estimatedReturn String        @map("estimated_return")
  profitBasis     ProfitBasis   @default(GROSS) @map("profit_basis")
  ctaLabel        String        @map("cta_label")
  featured        Boolean       @default(false)
  active          Boolean       @default(true)
  position        Int           @default(0)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  items           PackageItem[]

  @@index([featured])
  @@index([active])
  @@map("business_packages")
}

model PackageItem {
  id        String @id @default(uuid())
  packageId String @map("package_id")
  label     String
  quantity  String?
  position  Int    @default(0)

  package BusinessPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@map("package_items")
}

model Testimonial {
  id         String            @id @default(uuid())
  clientName String            @map("client_name")
  position   String?
  photo      String? // foto do cliente (IMAGE) ou poster do vídeo (VIDEO)
  videoUrl   String?           @map("video_url")
  content    String
  format     TestimonialFormat @default(TEXT)
  rating     Int? // 1–5
  featured   Boolean           @default(false)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  @@map("testimonials")
}

model BlogPost {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  excerpt        String
  cover          String?
  category       String
  author         String
  content        String // Markdown
  readingMinutes Int      @default(3) @map("reading_minutes")
  featured       Boolean  @default(false)
  published      Boolean  @default(true)
  publishedAt    DateTime @default(now()) @map("published_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([published])
  @@index([featured])
  @@index([category])
  @@map("blog_posts")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("contact_messages")
}

model SiteSettings {
  id          String   @id @default(uuid())
  companyName String   @map("company_name")
  email       String
  phone       String
  whatsapp    String
  address     String?
  facebook    String?
  instagram   String?
  youtube     String?
  linkedin    String?
  logo        String?
  heroTitle   String?  @map("hero_title")
  heroSubtitle String? @map("hero_subtitle")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
